# ========== 必填 ==========
DATABASE_URL="file:./prisma/dev.db"

# ========== 服务器 ==========
PORT=3000

# ========== 后台密码（公网务必设置）==========
ADMIN_AUTH_USER=admin
ADMIN_AUTH_PASSWORD=

# 本地临时关闭后台密码（生产不要开）
# ADMIN_AUTH_DISABLED=true

# ========== 不要写进本文件 ==========
# NODE_ENV —— Vite 构建时会报错；生产请用 PM2 / systemd / 命令行设置 NODE_ENV=production
# 见 ecosystem.config.cjs 或 deploy/AWS-DEPLOY.md

# ========== 可选 ==========
# GEMINI_API_KEY=
# DISABLE_HMR=true
