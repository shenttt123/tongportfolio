DATABASE_URL="file:./prisma/dev.db"

# --- Admin CMS (/admin + /api/admin) — HTTP Basic Auth ---
# If ADMIN_AUTH_PASSWORD is set, browser will ask for user/password before CMS loads.
# ADMIN_AUTH_USER=admin
# ADMIN_AUTH_PASSWORD=use-a-long-random-secret
# ADMIN_AUTH_DISABLED=true

# Prisma Studio (default port 5555) has no login screen.
# Safe options on a server: bind to loopback only + SSH tunnel, or put nginx with
# auth_basic in front — see deploy/nginx-prisma-studio-basic-auth.example.conf
